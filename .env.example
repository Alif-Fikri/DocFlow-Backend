# Copy to .env and adjust. docker-compose reads API_KEY from the environment.

# Port the HTTP server listens on.
PORT=8080

# Shared secret required in the X-API-Key header. Leave empty to DISABLE auth
# (development only — never expose an unauthenticated instance).
API_KEY=change-this-to-a-long-random-secret

# Path to the LibreOffice binary. "soffice" works inside the Docker image.
SOFFICE_BIN=soffice

# Maximum upload size in megabytes.
MAX_UPLOAD_MB=50

# Hard timeout for a single LibreOffice conversion, in seconds.
CONVERT_TIMEOUT_SEC=120

# Working directory for temporary files.
WORK_DIR=/tmp/docflow
